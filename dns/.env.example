# Timezone for Pi-hole (e.g., America/New_York, Asia/Singapore)
TIMEZONE=

# Password for the Pi-hole web interface (required)
PASSWORD=

# Additional upstream DNS servers for Pi-hole
# Unbound is always used as the primary upstream
# Example: 1.1.1.1
ADDITIONAL_DNS_SERVERS=

# /24 subnet prefix for the internal network between Pi-hole and Unbound
# Default: 172.24.0
# Example: 192.168.100
SUBNET_PREFIX=
