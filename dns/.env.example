# Timezone for Pi-hole (e.g., America/New_York, Asia/Singapore)
TIMEZONE=

# Password for the Pi-hole web interface (required)
PASSWORD=

# Additional upstream DNS servers for Pi-hole
# Unbound is always used as the primary upstream
# Example: 1.1.1.1
ADDITIONAL_DNS_SERVERS=

# /24 subnet prefix for the internal network between Pi-hole and Unbound
# Default: 172.24.0
# Example: 192.168.100
SUBNET_PREFIX=

# --- Sync (requires COMPOSE_PROFILES=sync) ---

# Remote Pi-hole replicas to sync to, using nebula-sync's native format
# Format: http://host:port|password,http://host2:port2|password2
# Required when sync profile is enabled
SYNC_REPLICAS=

# Sync schedule in cron format
# Default: */5 * * * *
SYNC_CRON=

# Enable full sync via Teleporter (true) or selective sync (false)
# Default: true
FULL_SYNC=

# Run gravity update on replicas after sync
# Default: false
# See: https://github.com/lovelaze/nebula-sync/issues/181
RUN_GRAVITY=
